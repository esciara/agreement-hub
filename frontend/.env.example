# Frontend environment variables
# Copy this file to .env.local and adjust as needed.

# Required when running `npm run preview` (Vite's built-in preview server
# does NOT proxy /api, so API calls would fail without this).
# Also useful for pointing the frontend at a remote backend.
# Leave unset during `npm run dev` — the Vite dev proxy handles /api automatically.
#
# VITE_API_BASE_URL=http://localhost:3001
